# ── Supabase (your hosted instance) ──────────────────────────────
SUPABASE_URL=your_supabse_url
SUPABASE_SERVICE_KEY=your_supabse_key
# ── Embeddings ────────────────────────────────────────────────────
EMBEDDING_PROVIDER=openai                # openai | voyage
OPENAI_API_KEY=your_openAi_key 
# ── API Auth ──────────────────────────────────────────────────────
MAAS_MASTER_KEY=master_key       # used to create tenant API keys

# ── App Settings ──────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
AUTO_SUMMARIZE_THRESHOLD=100              # memories before auto-compress
RECENCY_DECAY_LAMBDA=0.01


FLUTTERWAVE_SECRET_HASH=your_flutterwave_hash
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=support@memlayer.online


ENVIRONMENT=production
